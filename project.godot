; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HyperTag"
run/main_scene="res://Scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://blc3ylxy5afc4"

[autoload]

globalScript="*res://Scripts/global_script.gd"
music="*res://Scenes/music.tscn"
debugHud="*res://Scenes/debug_hud.tscn"
sceneTransition="*uid://doy2gu0dakdok"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/size/borderless=true
window/stretch/mode="viewport"
window/vsync/vsync_mode=0

[editor]

naming/node_name_casing=1
naming/scene_name_casing=4
naming/script_name_casing=4
version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray()

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Export/": "orange",
"res://Scenes/": "yellow",
"res://Scripts/": "green",
"res://Shaders/": "teal",
"res://Theme/": "blue"
}

[github_to_itch]

config/itch_username="Lipsum27"
config/itch_project_name=""

[global_group]

Players=""

[importer_defaults]

animation_library={
&"animation/fps": 120.0
}

